{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "cachos",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path'),m={'html':'text/html','js':'text/javascript','css':'text/css','json':'application/json'};h.createServer((q,r)=>{let u=q.url.split('?')[0];if(u==='/')u='/index.html';const fp=p.join(__dirname,'public',u);f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);return r.end('Not found')}const x=p.extname(fp).slice(1);r.writeHead(200,{'Content-Type':m[x]||'text/plain'});r.end(d)})}).listen(3000,()=>console.log('http://localhost:3000'))"],
      "port": 3000
    }
  ]
}
